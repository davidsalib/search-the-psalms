{
    "chapter_num": 146,
    "verses_count": 10,
    "paragraphs_list": [
        {
            "type": "section_header",
            "text": "The Happiness of Those Whose Help Is the Lord"
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 1,
                    "num_str": "1",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Praise"
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "Heb. Hallelujah"
                        },
                        {
                            "style": "NONE",
                            "text": " the "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": "!"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Praise the "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": ", O my soul!"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 2,
                    "num_str": "2",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "While I live I will praise the "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": ";"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "I will sing praises to my God while I have my being."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 3,
                    "num_str": "3",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Do not put your trust in princes,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "ITALIC",
                            "text": "Nor"
                        },
                        {
                            "style": "NONE",
                            "text": " in "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "A human being"
                        },
                        {
                            "style": "NONE",
                            "text": "a son of man, in whom "
                        },
                        {
                            "style": "ITALIC",
                            "text": "there is"
                        },
                        {
                            "style": "NONE",
                            "text": " no "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "salvation"
                        },
                        {
                            "style": "NONE",
                            "text": "help."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 4,
                    "num_str": "4",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "His spirit departs, he returns to his earth;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "In that very day his plans perish."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 5,
                    "num_str": "5",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Happy "
                        },
                        {
                            "style": "ITALIC",
                            "text": "is he"
                        },
                        {
                            "style": "NONE",
                            "text": " who "
                        },
                        {
                            "style": "ITALIC",
                            "text": "has"
                        },
                        {
                            "style": "NONE",
                            "text": " the God of Jacob for his help,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Whose hope "
                        },
                        {
                            "style": "ITALIC",
                            "text": "is"
                        },
                        {
                            "style": "NONE",
                            "text": " in the "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": " his God,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 6,
                    "num_str": "6",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Who made heaven and earth,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "The sea, and all that "
                        },
                        {
                            "style": "ITALIC",
                            "text": "is"
                        },
                        {
                            "style": "NONE",
                            "text": " in them;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Who keeps truth forever,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 7,
                    "num_str": "7",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Who executes justice for the oppressed,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Who gives food to the hungry."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "The "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": " gives freedom to the prisoners."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 8,
                    "num_str": "8",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "The "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": " opens "
                        },
                        {
                            "style": "ITALIC",
                            "text": "the eyes of"
                        },
                        {
                            "style": "NONE",
                            "text": " the blind;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "The "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": " raises those who are bowed down;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "The "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": " loves the righteous."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 9,
                    "num_str": "9",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "The "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": " watches over the strangers;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "He relieves the fatherless and widow;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "But the way of the wicked He "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "Lit. makes crooked"
                        },
                        {
                            "style": "NONE",
                            "text": "turns upside down."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 10,
                    "num_str": "10",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "The "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": " shall reign forever—"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Your God, O Zion, to all generations."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Praise the "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": "!"
                        }
                    ]
                }
            ]
        }
    ]
}