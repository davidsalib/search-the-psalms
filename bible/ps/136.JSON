{
    "chapter_num": 136,
    "verses_count": 26,
    "paragraphs_list": [
        {
            "type": "section_header",
            "text": "Thanksgiving to God for His Enduring Mercy"
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 1,
                    "num_str": "1",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Oh, give thanks to the "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": ", for "
                        },
                        {
                            "style": "ITALIC",
                            "text": "He is"
                        },
                        {
                            "style": "NONE",
                            "text": " good!"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "For His mercy "
                        },
                        {
                            "style": "ITALIC",
                            "text": "endures"
                        },
                        {
                            "style": "NONE",
                            "text": " forever."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 2,
                    "num_str": "2",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Oh, give thanks to the God of gods!"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "For His mercy "
                        },
                        {
                            "style": "ITALIC",
                            "text": "endures"
                        },
                        {
                            "style": "NONE",
                            "text": " forever."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 3,
                    "num_str": "3",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Oh, give thanks to the Lord of lords!"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "For His mercy "
                        },
                        {
                            "style": "ITALIC",
                            "text": "endures"
                        },
                        {
                            "style": "NONE",
                            "text": " forever:"
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 4,
                    "num_str": "4",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "To Him who alone does great wonders,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "For His mercy "
                        },
                        {
                            "style": "ITALIC",
                            "text": "endures"
                        },
                        {
                            "style": "NONE",
                            "text": " forever;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 5,
                    "num_str": "5",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "To Him who by wisdom made the heavens,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "For His mercy "
                        },
                        {
                            "style": "ITALIC",
                            "text": "endures"
                        },
                        {
                            "style": "NONE",
                            "text": " forever;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 6,
                    "num_str": "6",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "To Him who laid out the earth above the waters,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "For His mercy "
                        },
                        {
                            "style": "ITALIC",
                            "text": "endures"
                        },
                        {
                            "style": "NONE",
                            "text": " forever;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 7,
                    "num_str": "7",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "To Him who made great lights,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "For His mercy "
