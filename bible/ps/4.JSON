{
    "chapter_num": 4,
    "verses_count": 8,
    "paragraphs_list": [
        {
            "type": "section_header",
            "text": "The Safety of the Faithful"
        },
        {
            "type": "section_header",
            "text": "To the Chief Musician. With stringed instruments. A Psalm of David."
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 1,
                    "num_str": "1",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Hear me when I call, O God of my righteousness!"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "You have relieved me in "
                        },
                        {
                            "style": "ITALIC",
                            "text": "my"
                        },
                        {
                            "style": "NONE",
                            "text": " distress;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "Be gracious to me"
                        },
                        {
                            "style": "NONE",
                            "text": "Have mercy on me, and hear my prayer."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 2,
                    "num_str": "2",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "How long, O you sons of men,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "ITALIC",
                            "text": "Will you turn"
                        },
                        {
                            "style": "NONE",
                            "text": " my glory to shame?"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "ITALIC",
                            "text": "How long"
                        },
                        {
                            "style": "NONE",
                            "text": " will you love worthlessness"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "ITALIC",
                            "text": "And"
                        },
                        {
                            "style": "NONE",
                            "text": " seek falsehood? "
                        },
                        {
                            "style": "ITALIC",
                            "text": "Selah"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 3,
                    "num_str": "3",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "But know that the "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": " has "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "Many Heb. mss., LXX, Tg., Vg. made wonderful"
                        },
                        {
                            "style": "NONE",
                            "text": "set apart for Himself him who is godly;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "The "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": " will hear when I call to Him."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 4,
                    "num_str": "4",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Be"
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "Lit. Tremble or Be agitated"
                        },
                        {
                            "style": "NONE",
                            "text": " angry, and do not sin."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Meditate within your heart on your bed, and be still. "
                        },
                        {
                            "style": "ITALIC",
                            "text": "Selah"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 5,
                    "num_str": "5",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Offer the sacrifices of righteousness,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And put your trust in the "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": "."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 6,
                    "num_str": "6",
                    "verse_parts": [
                        {
                            "style": "ITALIC",
                            "text": "There are"
                        },
                        {
                            "style": "NONE",
                            "text": " many who say,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "“Who will show us "
                        },
                        {
                            "style": "ITALIC",
                            "text": "any"
                        },
                        {
                            "style": "NONE",
                            "text": " good?”"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": ", lift up the light of Your countenance upon us."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 7,
                    "num_str": "7",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "You have put gladness in my heart,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "More than in the season that their grain and wine increased."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 8,
                    "num_str": "8",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "I will both lie down in peace, and sleep;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "For You alone, O "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": ", make me dwell in safety."
                        }
                    ]
                }
            ]
        }
    ]
}