{
    "chapter_num": 38,
    "verses_count": 22,
    "paragraphs_list": [
        {
            "type": "section_header",
            "text": "Prayer in Time of Chastening"
        },
        {
            "type": "section_header",
            "text": "A Psalm of David. To bring to remembrance."
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 1,
                    "num_str": "1",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "O "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": ", do not rebuke me in Your wrath,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Nor chasten me in Your hot displeasure!"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 2,
                    "num_str": "2",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "For Your arrows pierce me deeply,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And Your hand presses me down."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 3,
                    "num_str": "3",
                    "verse_parts": [
                        {
                            "style": "ITALIC",
                            "text": "There is"
                        },
                        {
                            "style": "NONE",
                            "text": " no soundness in my flesh"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Because of Your anger,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Nor "
                        },
                        {
                            "style": "ITALIC",
                            "text": "any"
                        },
                        {
                            "style": "NONE",
                            "text": " health in my bones"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Because of my sin."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 4,
                    "num_str": "4",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "For my iniquities have gone over my head;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Like a heavy burden they are too heavy for me."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 5,
                    "num_str": "5",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "My wounds are foul "
                        },
                        {
                            "style": "ITALIC",
                            "text": "and"
                        },
                        {
                            "style": "NONE",
                            "text": " festering"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Because of my foolishness."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 6,
                    "num_str": "6",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "I am "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "Lit. bent down"
                        },
                        {
                            "style": "NONE",
                            "text": "troubled, I am bowed down greatly;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "I go mourning all the day long."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 7,
                    "num_str": "7",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "For my loins are full of inflammation,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And "
                        },
                        {
                            "style": "ITALIC",
                            "text": "there is"
                        },
                        {
                            "style": "NONE",
                            "text": " no soundness in my flesh."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 8,
                    "num_str": "8",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "I am feeble and severely broken;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "I groan because of the turmoil of my heart."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 9,
                    "num_str": "9",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Lord, all my desire "
                        },
                        {
                            "style": "ITALIC",
                            "text": "is"
                        },
                        {
                            "style": "NONE",
                            "text": " before You;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And my sighing is not hidden from You."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 10,
                    "num_str": "10",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "My heart pants, my strength fails me;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "As for the light of my eyes, it also has gone from me."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 11,
                    "num_str": "11",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "My loved ones and my friends stand aloof from my plague,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And my relatives stand afar off."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 12,
                    "num_str": "12",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Those also who seek my life lay snares "
                        },
                        {
                            "style": "ITALIC",
                            "text": "for me;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Those who seek my hurt speak of destruction,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And plan deception all the day long."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 13,
                    "num_str": "13",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "But I, like a deaf "
                        },
                        {
                            "style": "ITALIC",
                            "text": "man,"
                        },
                        {
                            "style": "NONE",
                            "text": " do not hear;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And "
                        },
                        {
                            "style": "ITALIC",
                            "text": "I am"
                        },
                        {
                            "style": "NONE",
                            "text": " like a mute "
                        },
                        {
                            "style": "ITALIC",
                            "text": "who"
                        },
                        {
                            "style": "NONE",
                            "text": " does not open his mouth."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 14,
                    "num_str": "14",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Thus I am like a man who does not hear,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And in whose mouth "
                        },
                        {
                            "style": "ITALIC",
                            "text": "is"
                        },
                        {
                            "style": "NONE",
                            "text": " no response."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 15,
                    "num_str": "15",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "For "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "I wait for You, O Lord"
                        },
                        {
                            "style": "NONE",
                            "text": "in You, O "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": ", I hope;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "You will "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "answer"
                        },
                        {
                            "style": "NONE",
                            "text": "hear, O Lord my God."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 16,
                    "num_str": "16",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "For I said, “"
                        },
                        {
                            "style": "ITALIC",
                            "text": "Hear me,"
                        },
                        {
                            "style": "NONE",
                            "text": " lest they rejoice over me,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Lest, when my foot slips, they exalt "
                        },
                        {
                            "style": "ITALIC",
                            "text": "themselves"
                        },
                        {
                            "style": "NONE",
                            "text": " against me.”"
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 17,
                    "num_str": "17",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "For I "
                        },
                        {
                            "style": "ITALIC",
                            "text": "am"
                        },
                        {
                            "style": "NONE",
                            "text": " ready to fall,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And my sorrow "
                        },
                        {
                            "style": "ITALIC",
                            "text": "is"
                        },
                        {
                            "style": "NONE",
                            "text": " continually before me."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 18,
                    "num_str": "18",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "For I will declare my iniquity;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "I will be in "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "anxiety"
                        },
                        {
                            "style": "NONE",
                            "text": "anguish over my sin."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 19,
                    "num_str": "19",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "But my enemies "
                        },
                        {
                            "style": "ITALIC",
                            "text": "are"
                        },
                        {
                            "style": "NONE",
                            "text": " vigorous, "
                        },
                        {
                            "style": "ITALIC",
                            "text": "and"
                        },
                        {
                            "style": "NONE",
                            "text": " they are strong;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And those who hate me wrongfully have multiplied."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 20,
                    "num_str": "20",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Those also who render evil for good,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "They are my adversaries, because I follow "
                        },
                        {
                            "style": "ITALIC",
                            "text": "what is"
                        },
                        {
                            "style": "NONE",
                            "text": " good."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 21,
                    "num_str": "21",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Do not forsake me, O "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": ";"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "O my God, be not far from me!"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 22,
                    "num_str": "22",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Make haste to help me,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "O Lord, my salvation!"
                        }
                    ]
                }
            ]
        }
    ]
}