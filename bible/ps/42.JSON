{
    "chapter_num": 42,
    "verses_count": 11,
    "paragraphs_list": [
        {
            "type": "section_header",
            "text": "Yearning for God in the Midst of Distresses"
        },
        {
            "type": "section_header",
            "text": "To the Chief Musician. A Contemplation of the sons of Korah."
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 1,
                    "num_str": "1",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "As the deer "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "Lit. longs for"
                        },
                        {
                            "style": "NONE",
                            "text": "pants for the water brooks,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "So pants my soul for You, O God."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 2,
                    "num_str": "2",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "My soul thirsts for God, for the living God."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "When shall I come and "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "So with MT, Vg.; some Heb. mss., LXX, Syr., Tg. I see the face of God"
                        },
                        {
                            "style": "NONE",
                            "text": "appear before God?"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 3,
                    "num_str": "3",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "My tears have been my food day and night,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "While they continually say to me,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "“Where "
                        },
                        {
                            "style": "ITALIC",
                            "text": "is"
                        },
                        {
                            "style": "NONE",
                            "text": " your God?”"
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 4,
                    "num_str": "4",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "When I remember these "
                        },
                        {
                            "style": "ITALIC",
                            "text": "things,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "I pour out my soul within me."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "For I used to go with the multitude;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "I went with them to the house of God,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "With the voice of joy and praise,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "With a multitude that kept a pilgrim feast."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 5,
                    "num_str": "5",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Why are you "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "Lit. bowed down"
                        },
                        {
                            "style": "NONE",
                            "text": "cast down, O my soul?"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And "
                        },
                        {
                            "style": "ITALIC",
                            "text": "why"
                        },
                        {
                            "style": "NONE",
                            "text": " are you disquieted within me?"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Hope in God, for I shall yet praise Him"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "So with MT, Tg.; a few Heb. mss., LXX, Syr., Vg. The help of my countenance, my God"
                        },
                        {
                            "style": "ITALIC",
                            "text": "For"
                        },
                        {
                            "style": "NONE",
                            "text": " the help of His countenance."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 6,
                    "num_str": "6",
                    "verse_parts": [
                        {
                            "style": "FOOTNOTE",
                            "text": "So with MT, Tg.; a few Heb. mss., LXX, Syr., Vg. put my God at the end of v. 5"
                        },
                        {
                            "style": "NONE",
                            "text": "O my God, my soul is cast down within me;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Therefore I will remember You from the land of the Jordan,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And from the heights of Hermon,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "From "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "Or Mount"
                        },
                        {
                            "style": "NONE",
                            "text": "the Hill Mizar."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 7,
                    "num_str": "7",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Deep calls unto deep at the noise of Your waterfalls;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "All Your waves and billows have gone over me."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 8,
                    "num_str": "8",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "The "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": " will command His lovingkindness in the daytime,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And in the night His song "
                        },
                        {
                            "style": "ITALIC",
                            "text": "shall be"
                        },
                        {
                            "style": "NONE",
                            "text": " with me—"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "A prayer to the God of my life."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 9,
                    "num_str": "9",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "I will say to God my Rock,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "“Why have You forgotten me?"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Why do I go mourning because of the oppression of the enemy?”"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 10,
                    "num_str": "10",
                    "verse_parts": [
                        {
                            "style": "ITALIC",
                            "text": "As"
                        },
                        {
                            "style": "NONE",
                            "text": " with a "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "Lit. shattering"
                        },
                        {
                            "style": "NONE",
                            "text": "breaking of my bones,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "My enemies "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "revile"
                        },
                        {
                            "style": "NONE",
                            "text": "reproach me,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "While they say to me all day long,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "“Where "
                        },
                        {
                            "style": "ITALIC",
                            "text": "is"
                        },
                        {
                            "style": "NONE",
                            "text": " your God?”"
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 11,
                    "num_str": "11",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Why are you cast down, O my soul?"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And why are you disquieted within me?"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Hope in God;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "For I shall yet praise Him,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "The "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "Lit. salvation"
                        },
                        {
                            "style": "NONE",
                            "text": "help of my countenance and my God."
                        }
                    ]
                }
            ]
        }
    ]
}