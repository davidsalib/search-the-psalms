{
    "chapter_num": 31,
    "verses_count": 24,
    "paragraphs_list": [
        {
            "type": "section_header",
            "text": "The Lord a Fortress in Adversity"
        },
        {
            "type": "section_header",
            "text": "To the Chief Musician. A Psalm of David."
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 1,
                    "num_str": "1",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "In You, O "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": ", I "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "have taken refuge"
                        },
                        {
                            "style": "NONE",
                            "text": "put my trust;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Let me never be ashamed;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Deliver me in Your righteousness."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 2,
                    "num_str": "2",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Bow down Your ear to me,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Deliver me speedily;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Be my rock of "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "strength"
                        },
                        {
                            "style": "NONE",
                            "text": "refuge,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "A "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "Lit. house of fortresses"
                        },
                        {
                            "style": "NONE",
                            "text": "fortress of defense to save me."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 3,
                    "num_str": "3",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "For You "
                        },
                        {
                            "style": "ITALIC",
                            "text": "are"
                        },
                        {
                            "style": "NONE",
                            "text": " my rock and my fortress;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Therefore, for Your name’s sake,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Lead me and guide me."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 4,
                    "num_str": "4",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Pull me out of the net which they have secretly laid for me,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "For You "
                        },
                        {
                            "style": "ITALIC",
                            "text": "are"
                        },
                        {
                            "style": "NONE",
                            "text": " my strength."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 5,
                    "num_str": "5",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Into Your hand I commit my spirit;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "You have redeemed me, O "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": " God of truth."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 6,
                    "num_str": "6",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "I have hated those who regard useless idols;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "But I trust in the "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": "."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 7,
                    "num_str": "7",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "I will be glad and rejoice in Your mercy,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "For You have considered my trouble;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "You have known my soul in "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "troubles"
                        },
                        {
                            "style": "NONE",
                            "text": "adversities,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 8,
                    "num_str": "8",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "And have not shut"
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "given me over"
                        },
                        {
                            "style": "NONE",
                            "text": " me up into the hand of the enemy;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "You have set my feet in a wide place."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 9,
                    "num_str": "9",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Have mercy on me, O "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": ", for I am in trouble;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "My eye wastes away with grief,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "ITALIC",
                            "text": "Yes,"
                        },
                        {
                            "style": "NONE",
                            "text": " my soul and my "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "Lit. belly"
                        },
                        {
                            "style": "NONE",
                            "text": "body!"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 10,
                    "num_str": "10",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "For my life is spent with grief,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And my years with sighing;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "My strength fails because of my iniquity,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And my bones waste away."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 11,
                    "num_str": "11",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "I am a "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "despised thing"
                        },
                        {
                            "style": "NONE",
                            "text": "reproach among all my enemies,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "But especially among my neighbors,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And "
                        },
                        {
                            "style": "ITALIC",
                            "text": "am"
                        },
                        {
                            "style": "NONE",
                            "text": " repulsive to my acquaintances;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Those who see me outside flee from me."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 12,
                    "num_str": "12",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "I am forgotten like a dead man, out of mind;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "I am like a "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "Lit. perishing"
                        },
                        {
                            "style": "NONE",
                            "text": "broken vessel."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 13,
                    "num_str": "13",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "For I hear the slander of many;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Fear "
                        },
                        {
                            "style": "ITALIC",
                            "text": "is"
                        },
                        {
                            "style": "NONE",
                            "text": " on every side;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "While they take counsel together against me,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "They scheme to take away my life."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 14,
                    "num_str": "14",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "But as for me, I trust in You, O "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": ";"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "I say, “You "
                        },
                        {
                            "style": "ITALIC",
                            "text": "are"
                        },
                        {
                            "style": "NONE",
                            "text": " my God.”"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 15,
                    "num_str": "15",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "My times "
                        },
                        {
                            "style": "ITALIC",
                            "text": "are"
                        },
                        {
                            "style": "NONE",
                            "text": " in Your hand;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Deliver me from the hand of my enemies,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And from those who persecute me."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 16,
                    "num_str": "16",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Make Your face shine upon Your servant;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Save me for Your mercies’ sake."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 17,
                    "num_str": "17",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Do not let me be ashamed, O "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": ", for I have called upon You;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Let the wicked be ashamed;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Let them be silent in the grave."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 18,
                    "num_str": "18",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Let the lying lips be put to silence,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Which speak insolent things proudly and contemptuously against the righteous."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 19,
                    "num_str": "19",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Oh, how great "
                        },
                        {
                            "style": "ITALIC",
                            "text": "is"
                        },
                        {
                            "style": "NONE",
                            "text": " Your goodness,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Which You have laid up for those who fear You,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "ITALIC",
                            "text": "Which"
                        },
                        {
                            "style": "NONE",
                            "text": " You have prepared for those who trust in You"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "In the presence of the sons of men!"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 20,
                    "num_str": "20",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "You shall hide them in the secret place of Your presence"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "From the plots of man;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "You shall keep them secretly in a "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "shelter"
                        },
                        {
                            "style": "NONE",
                            "text": "pavilion"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "From the strife of tongues."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 21,
                    "num_str": "21",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Blessed "
                        },
                        {
                            "style": "ITALIC",
                            "text": "be"
                        },
                        {
                            "style": "NONE",
                            "text": " the "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": ","
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "For He has shown me His marvelous kindness in a "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "fortified"
                        },
                        {
                            "style": "NONE",
                            "text": "strong city!"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 22,
                    "num_str": "22",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "For I said in my haste,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "“I am cut off from before Your eyes”;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Nevertheless You heard the voice of my supplications"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "When I cried out to You."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 23,
                    "num_str": "23",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Oh, love the "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": ", all you His saints!"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "ITALIC",
                            "text": "For"
                        },
                        {
                            "style": "NONE",
                            "text": " the "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": " preserves the faithful,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And fully repays the proud person."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 24,
                    "num_str": "24",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Be of good courage,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And He shall strengthen your heart,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "All you who hope in the "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": "."
                        }
                    ]
                }
            ]
        }
    ]
}