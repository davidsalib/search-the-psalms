                    ]
                },
                {
                    "num_int": 45,
                    "num_str": "45",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "That they might observe His statutes"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
