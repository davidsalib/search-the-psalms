                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 43,
                    "num_str": "43",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "He brought out His people with joy,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "His chosen ones with "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "a joyful shout"
                        },
                        {
                            "style": "NONE",
                            "text": "gladness."
