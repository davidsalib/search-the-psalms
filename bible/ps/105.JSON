                {
                    "num_int": 42,
                    "num_str": "42",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "For He remembered His holy promise,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "ITALIC",
                            "text": "And"
