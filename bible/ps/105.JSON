                    ]
                },
                {
                    "num_int": 44,
                    "num_str": "44",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "He gave them the lands of the "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "nations"
                        },
                        {
                            "style": "NONE",
                            "text": "Gentiles,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And they inherited the labor of the nations,"
