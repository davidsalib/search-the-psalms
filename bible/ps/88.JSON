{
    "chapter_num": 88,
    "verses_count": 18,
    "paragraphs_list": [
        {
            "type": "section_header",
            "text": "A Prayer for Help in Despondency"
        },
        {
            "type": "section_header",
            "text": "A Song. A Psalm of the sons of Korah. To the Chief Musician. Set to “Mahalath Leannoth.” A Contemplation of Heman the Ezrahite."
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 1,
                    "num_str": "1",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "O "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": ", God of my salvation,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "I have cried out day and night before You."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 2,
                    "num_str": "2",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Let my prayer come before You;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "Listen to"
                        },
                        {
                            "style": "NONE",
                            "text": "Incline Your ear to my cry."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 3,
                    "num_str": "3",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "For my soul is full of troubles,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And my life draws near to the grave."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 4,
                    "num_str": "4",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "I am counted with those who go"
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "Die"
                        },
                        {
                            "style": "NONE",
                            "text": " down to the pit;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "I am like a man "
                        },
                        {
                            "style": "ITALIC",
                            "text": "who has"
                        },
                        {
                            "style": "NONE",
                            "text": " no strength,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 5,
                    "num_str": "5",
                    "verse_parts": [
                        {
                            "style": "FOOTNOTE",
                            "text": "Lit. Free"
                        },
                        {
                            "style": "NONE",
                            "text": "Adrift among the dead,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Like the slain who lie in the grave,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Whom You remember no more,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And who are cut off from Your hand."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 6,
                    "num_str": "6",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "You have laid me in the lowest pit,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "In darkness, in the depths."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 7,
                    "num_str": "7",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Your wrath lies heavy upon me,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And You have afflicted "
                        },
                        {
                            "style": "ITALIC",
                            "text": "me"
                        },
                        {
                            "style": "NONE",
                            "text": " with all Your waves. "
                        },
                        {
                            "style": "ITALIC",
                            "text": "Selah"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 8,
                    "num_str": "8",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "You have "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "taken away my friends"
                        },
                        {
                            "style": "NONE",
                            "text": "put away my acquaintances far from me;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "You have made me an abomination to them;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "ITALIC",
                            "text": "I am"
                        },
                        {
                            "style": "NONE",
                            "text": " shut up, and I cannot get out;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 9,
                    "num_str": "9",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "My eye wastes away because of affliction."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": ", I have called daily upon You;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "I have stretched out my hands to You."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 10,
                    "num_str": "10",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Will You work wonders for the dead?"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Shall "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "shades, ghosts"
                        },
                        {
                            "style": "NONE",
                            "text": "the dead arise "
                        },
                        {
                            "style": "ITALIC",
                            "text": "and"
                        },
                        {
                            "style": "NONE",
                            "text": " praise You? "
                        },
                        {
                            "style": "ITALIC",
                            "text": "Selah"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 11,
                    "num_str": "11",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Shall Your lovingkindness be declared in the grave?"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "ITALIC",
                            "text": "Or"
                        },
                        {
                            "style": "NONE",
                            "text": " Your faithfulness in the place of destruction?"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 12,
                    "num_str": "12",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Shall Your wonders be known in the dark?"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And Your righteousness in the land of forgetfulness?"
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 13,
                    "num_str": "13",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "But to You I have cried out, O "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": ","
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And in the morning my prayer comes before You."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 14,
                    "num_str": "14",
                    "verse_parts": [
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": ", why do You cast off my soul?"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "ITALIC",
                            "text": "Why"
                        },
                        {
                            "style": "NONE",
                            "text": " do You hide Your face from me?"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 15,
                    "num_str": "15",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "I "
                        },
                        {
                            "style": "ITALIC",
                            "text": "have been"
                        },
                        {
                            "style": "NONE",
                            "text": " afflicted and ready to die from "
                        },
                        {
                            "style": "ITALIC",
                            "text": "my"
                        },
                        {
                            "style": "NONE",
                            "text": " youth;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "I suffer Your terrors;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "I am distraught."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 16,
                    "num_str": "16",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Your fierce wrath has gone over me;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Your terrors have "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "destroyed me"
                        },
                        {
                            "style": "NONE",
                            "text": "cut me off."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 17,
                    "num_str": "17",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "They came around me all day long like water;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "They engulfed me altogether."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 18,
                    "num_str": "18",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Loved one and friend You have put far from me,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "ITALIC",
                            "text": "And"
                        },
                        {
                            "style": "NONE",
                            "text": " my acquaintances into darkness."
                        }
                    ]
                }
            ]
        }
    ]
}