{
    "chapter_num": 131,
    "verses_count": 3,
    "paragraphs_list": [
        {
            "type": "section_header",
            "text": "Simple Trust in the Lord"
        },
        {
            "type": "section_header",
            "text": "A Song of Ascents. Of David."
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 1,
                    "num_str": "1",
                    "verse_parts": [
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": ", my heart is not "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "Proud"
                        },
                        {
                            "style": "NONE",
                            "text": "haughty,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Nor my eyes "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "Arrogant"
                        },
                        {
                            "style": "NONE",
                            "text": "lofty."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Neither do I "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "Lit. walk in"
                        },
                        {
                            "style": "NONE",
                            "text": "concern myself with great matters,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Nor with things too "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "difficult"
                        },
                        {
                            "style": "NONE",
                            "text": "profound for me."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 2,
                    "num_str": "2",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Surely I have calmed and quieted my soul,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Like a weaned child with his mother;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Like a weaned child "
                        },
                        {
                            "style": "ITALIC",
                            "text": "is"
                        },
                        {
                            "style": "NONE",
                            "text": " my soul within me."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 3,
                    "num_str": "3",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "O Israel, hope in the "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "From this time forth and forever."
                        }
                    ]
                }
            ]
        }
    ]
}