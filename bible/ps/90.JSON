{
    "chapter_num": 90,
    "verses_count": 17,
    "paragraphs_list": [
        {
            "type": "section_header",
            "text": "The Eternity of God, and Man’s Frailty"
        },
        {
            "type": "section_header",
            "text": "A Prayer of Moses the man of God."
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 1,
                    "num_str": "1",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Lord, You have been our "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "LXX, Tg., Vg. refuge"
                        },
                        {
                            "style": "NONE",
                            "text": "dwelling place in all generations."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 2,
                    "num_str": "2",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Before the mountains were brought forth,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Or ever You "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "Lit. gave birth to"
                        },
                        {
                            "style": "NONE",
                            "text": "had formed the earth and the world,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Even from everlasting to everlasting, You "
                        },
                        {
                            "style": "ITALIC",
                            "text": "are"
                        },
                        {
                            "style": "NONE",
                            "text": " God."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 3,
                    "num_str": "3",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "You turn man to destruction,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And say, “Return, O children of men.”"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 4,
                    "num_str": "4",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "For a thousand years in Your sight"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "ITALIC",
                            "text": "Are"
                        },
                        {
                            "style": "NONE",
                            "text": " like yesterday when it is past,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And "
                        },
                        {
                            "style": "ITALIC",
                            "text": "like"
                        },
                        {
                            "style": "NONE",
                            "text": " a watch in the night."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 5,
                    "num_str": "5",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "You carry them away "
                        },
                        {
                            "style": "ITALIC",
                            "text": "like"
                        },
                        {
                            "style": "NONE",
                            "text": " a flood;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "ITALIC",
                            "text": "They are"
                        },
                        {
                            "style": "NONE",
                            "text": " like a sleep."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "In the morning they are like grass "
                        },
                        {
                            "style": "ITALIC",
                            "text": "which"
                        },
                        {
                            "style": "NONE",
                            "text": " grows up:"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 6,
                    "num_str": "6",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "In the morning it flourishes and grows up;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "In the evening it is cut down and withers."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 7,
                    "num_str": "7",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "For we have been consumed by Your anger,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And by Your wrath we are terrified."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 8,
                    "num_str": "8",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "You have set our iniquities before You,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Our secret "
                        },
                        {
                            "style": "ITALIC",
                            "text": "sins"
                        },
                        {
                            "style": "NONE",
                            "text": " in the light of Your countenance."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 9,
                    "num_str": "9",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "For all our days have passed away in Your wrath;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "We finish our years like a sigh."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 10,
                    "num_str": "10",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "The days of our lives "
                        },
                        {
                            "style": "ITALIC",
                            "text": "are"
                        },
                        {
                            "style": "NONE",
                            "text": " seventy years;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And if by reason of strength "
                        },
                        {
                            "style": "ITALIC",
                            "text": "they are"
                        },
                        {
                            "style": "NONE",
                            "text": " eighty years,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Yet their boast "
                        },
                        {
                            "style": "ITALIC",
                            "text": "is"
                        },
                        {
                            "style": "NONE",
                            "text": " only labor and sorrow;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "For it is soon cut off, and we fly away."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 11,
                    "num_str": "11",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Who knows the power of Your anger?"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "For as the fear of You, "
                        },
                        {
                            "style": "ITALIC",
                            "text": "so is"
                        },
                        {
                            "style": "NONE",
                            "text": " Your wrath."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 12,
                    "num_str": "12",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "So teach "
                        },
                        {
                            "style": "ITALIC",
                            "text": "us"
                        },
                        {
                            "style": "NONE",
                            "text": " to number our days,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "That we may gain a heart of wisdom."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 13,
                    "num_str": "13",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Return, O "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": "!"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "How long?"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And have compassion on Your servants."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 14,
                    "num_str": "14",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Oh, satisfy us early with Your mercy,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "That we may rejoice and be glad all our days!"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 15,
                    "num_str": "15",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Make us glad according to the days "
                        },
                        {
                            "style": "ITALIC",
                            "text": "in which"
                        },
                        {
                            "style": "NONE",
                            "text": " You have afflicted us,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "The years "
                        },
                        {
                            "style": "ITALIC",
                            "text": "in which"
                        },
                        {
                            "style": "NONE",
                            "text": " we have seen evil."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 16,
                    "num_str": "16",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Let Your work appear to Your servants,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And Your glory to their children."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 17,
                    "num_str": "17",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "And let the beauty of the "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": " our God be upon us,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And establish the work of our hands for us;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Yes, establish the work of our hands."
                        }
                    ]
                }
            ]
        }
    ]
}