{
    "chapter_num": 27,
    "verses_count": 14,
    "paragraphs_list": [
        {
            "type": "section_header",
            "text": "An Exuberant Declaration of Faith"
        },
        {
            "type": "section_header",
            "text": "A Psalm of David."
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 1,
                    "num_str": "1",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "The "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": " "
                        },
                        {
                            "style": "ITALIC",
                            "text": "is"
                        },
                        {
                            "style": "NONE",
                            "text": " my light and my salvation;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Whom shall I fear?"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "The "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": " "
                        },
                        {
                            "style": "ITALIC",
                            "text": "is"
                        },
                        {
                            "style": "NONE",
                            "text": " the strength of my life;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Of whom shall I be afraid?"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 2,
                    "num_str": "2",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "When the wicked came against me"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "To eat"
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "devour"
                        },
                        {
                            "style": "NONE",
                            "text": " up my flesh,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "My enemies and foes,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "They stumbled and fell."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 3,
                    "num_str": "3",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Though an army may encamp against me,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "My heart shall not fear;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Though war may rise against me,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "In this I "
                        },
                        {
                            "style": "ITALIC",
                            "text": "will be"
                        },
                        {
                            "style": "NONE",
                            "text": " confident."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 4,
                    "num_str": "4",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "One "
                        },
                        {
                            "style": "ITALIC",
                            "text": "thing"
                        },
                        {
                            "style": "NONE",
                            "text": " I have desired of the "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": ","
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "That will I seek:"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "That I may dwell in the house of the "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "All the days of my life,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "To behold the "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "delightfulness"
                        },
                        {
                            "style": "NONE",
                            "text": "beauty of the "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": ","
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And to inquire in His temple."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 5,
                    "num_str": "5",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "For in the time of trouble"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "He shall hide me in His pavilion;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "In the secret place of His tabernacle"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "He shall hide me;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "He shall set me high upon a rock."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 6,
                    "num_str": "6",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "And now my head shall be "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "Lifted up in honor"
                        },
                        {
                            "style": "NONE",
                            "text": "lifted up above my enemies all around me;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Therefore I will offer sacrifices of "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "joyous shouts"
                        },
                        {
                            "style": "NONE",
                            "text": "joy in His tabernacle;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "I will sing, yes, I will sing praises to the "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": "."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 7,
                    "num_str": "7",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Hear, O "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": ", "
                        },
                        {
                            "style": "ITALIC",
                            "text": "when"
                        },
                        {
                            "style": "NONE",
                            "text": " I cry with my voice!"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Have mercy also upon me, and answer me."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 8,
                    "num_str": "8",
                    "verse_parts": [
                        {
                            "style": "ITALIC",
                            "text": "When You said,"
                        },
                        {
                            "style": "NONE",
                            "text": " “Seek My face,”"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "My heart said to You, “Your face, "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": ", I will seek.”"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 9,
                    "num_str": "9",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Do not hide Your face from me;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Do not turn Your servant away in anger;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "You have been my help;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Do not leave me nor forsake me,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "O God of my salvation."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 10,
                    "num_str": "10",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "When my father and my mother forsake me,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Then the "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": " will take care of me."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 11,
                    "num_str": "11",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Teach me Your way, O "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": ","
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And lead me in a smooth path, because of my enemies."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 12,
                    "num_str": "12",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Do not deliver me to the will of my adversaries;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "For false witnesses have risen against me,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And such as breathe out violence."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 13,
                    "num_str": "13",
                    "verse_parts": [
                        {
                            "style": "ITALIC",
                            "text": "I would have lost heart,"
                        },
                        {
                            "style": "NONE",
                            "text": " unless I had believed"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "That I would see the goodness of the "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "In the land of the living."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 14,
                    "num_str": "14",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Wait"
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "Wait in faith"
                        },
                        {
                            "style": "NONE",
                            "text": " on the "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": ";"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Be of good courage,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And He shall strengthen your heart;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Wait, I say, on the "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": "!"
                        }
                    ]
                }
            ]
        }
    ]
}