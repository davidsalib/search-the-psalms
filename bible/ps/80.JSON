{
    "chapter_num": 80,
    "verses_count": 19,
    "paragraphs_list": [
        {
            "type": "section_header",
            "text": "Prayer for Israel’s Restoration"
        },
        {
            "type": "section_header",
            "text": "To the Chief Musician. Set to “The Lilies.” A Testimony of Asaph. A Psalm."
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 1,
                    "num_str": "1",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Give ear, O Shepherd of Israel,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "You who lead Joseph like a flock;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "You who dwell "
                        },
                        {
                            "style": "ITALIC",
                            "text": "between"
                        },
                        {
                            "style": "NONE",
                            "text": " the cherubim, shine forth!"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 2,
                    "num_str": "2",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Before Ephraim, Benjamin, and Manasseh,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Stir up Your strength,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And come "
                        },
                        {
                            "style": "ITALIC",
                            "text": "and"
                        },
                        {
                            "style": "NONE",
                            "text": " save us!"
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 3,
                    "num_str": "3",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Restore us, O God;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Cause Your face to shine,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And we shall be saved!"
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 4,
                    "num_str": "4",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "O "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": " God of hosts,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "How long will You be angry"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Against the prayer of Your people?"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 5,
                    "num_str": "5",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "You have fed them with the bread of tears,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And given them tears to drink in great measure."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 6,
                    "num_str": "6",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "You have made us a strife to our neighbors,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And our enemies laugh among themselves."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 7,
                    "num_str": "7",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Restore us, O God of hosts;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Cause Your face to shine,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And we shall be saved!"
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 8,
                    "num_str": "8",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "You have brought a vine out of Egypt;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "You have cast out the "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "Gentiles"
                        },
                        {
                            "style": "NONE",
                            "text": "nations, and planted it."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 9,
                    "num_str": "9",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "You prepared "
                        },
                        {
                            "style": "ITALIC",
                            "text": "room"
                        },
                        {
                            "style": "NONE",
                            "text": " for it,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And caused it to take deep root,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And it filled the land."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 10,
                    "num_str": "10",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "The hills were covered with its shadow,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And the "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "Lit. cedars of God"
                        },
                        {
                            "style": "NONE",
                            "text": "mighty cedars with its boughs."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 11,
                    "num_str": "11",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "She sent out her boughs to "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "The Mediterranean"
                        },
                        {
                            "style": "NONE",
                            "text": "the Sea,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And her branches to "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "The Euphrates"
                        },
                        {
                            "style": "NONE",
                            "text": "the River."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 12,
                    "num_str": "12",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Why have You broken down her "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "walls or fences"
                        },
                        {
                            "style": "NONE",
                            "text": "hedges,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "So that all who pass by the way pluck her "
                        },
                        {
                            "style": "ITALIC",
                            "text": "fruit?"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 13,
                    "num_str": "13",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "The boar out of the woods uproots it,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And the wild beast of the field devours it."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 14,
                    "num_str": "14",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Return, we beseech You, O God of hosts;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Look down from heaven and see,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And visit this vine"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 15,
                    "num_str": "15",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "And the vineyard which Your right hand has planted,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And the branch "
                        },
                        {
                            "style": "ITALIC",
                            "text": "that"
                        },
                        {
                            "style": "NONE",
                            "text": " You made strong for Yourself."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 16,
                    "num_str": "16",
                    "verse_parts": [
                        {
                            "style": "ITALIC",
                            "text": "It is"
                        },
                        {
                            "style": "NONE",
                            "text": " burned with fire, "
                        },
                        {
                            "style": "ITALIC",
                            "text": "it is"
                        },
                        {
                            "style": "NONE",
                            "text": " cut down;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "They perish at the rebuke of Your countenance."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 17,
                    "num_str": "17",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Let Your hand be upon the man of Your right hand,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Upon the son of man "
                        },
                        {
                            "style": "ITALIC",
                            "text": "whom"
                        },
                        {
                            "style": "NONE",
                            "text": " You made strong for Yourself."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 18,
                    "num_str": "18",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Then we will not turn back from You;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Revive us, and we will call upon Your name."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 19,
                    "num_str": "19",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Restore us, O "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": " God of hosts;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Cause Your face to shine,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And we shall be saved!"
                        }
                    ]
                }
            ]
        }
    ]
}