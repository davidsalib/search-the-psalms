{
    "chapter_num": 2,
    "verses_count": 12,
    "paragraphs_list": [
        {
            "type": "section_header",
            "text": "The Messiah’s Triumph and Kingdom"
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 1,
                    "num_str": "1",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Why do the "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "Gentiles"
                        },
                        {
                            "style": "NONE",
                            "text": "nations "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "throng tumultuously"
                        },
                        {
                            "style": "NONE",
                            "text": "rage,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And the people plot a "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "worthless or empty"
                        },
                        {
                            "style": "NONE",
                            "text": "vain thing?"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 2,
                    "num_str": "2",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "The kings of the earth set themselves,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And the rulers take counsel together,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Against the "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": " and against His Anointed,"
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "Christ, Commissioned One, Heb. Messiah"
                        },
                        {
                            "style": "NONE",
                            "text": " "
                        },
                        {
                            "style": "ITALIC",
                            "text": "saying,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 3,
                    "num_str": "3",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "“Let us break Their bonds in pieces"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And cast away Their cords from us.”"
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 4,
                    "num_str": "4",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "He who sits in the heavens shall laugh;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "The Lord shall hold them in derision."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 5,
                    "num_str": "5",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Then He shall speak to them in His wrath,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And distress them in His deep displeasure:"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 6,
                    "num_str": "6",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "“Yet I have "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "Lit. installed"
                        },
                        {
                            "style": "NONE",
                            "text": "set My King"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "Lit. Upon Zion, the hill of My holiness"
                        },
                        {
                            "style": "NONE",
                            "text": "On My holy hill of Zion.”"
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 7,
                    "num_str": "7",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "“I will declare the "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "Or decree of the Lord: He said to Me"
                        },
                        {
                            "style": "NONE",
                            "text": "decree:"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "The "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": " has said to Me,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "‘You "
                        },
                        {
                            "style": "ITALIC",
                            "text": "are"
                        },
                        {
                            "style": "NONE",
                            "text": " My Son,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Today I have begotten You."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 8,
                    "num_str": "8",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Ask of Me, and I will give "
                        },
                        {
                            "style": "ITALIC",
                            "text": "You"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "The nations "
                        },
                        {
                            "style": "ITALIC",
                            "text": "for"
                        },
                        {
                            "style": "NONE",
                            "text": " Your inheritance,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And the ends of the earth "
                        },
                        {
                            "style": "ITALIC",
                            "text": "for"
                        },
                        {
                            "style": "NONE",
                            "text": " Your possession."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 9,
                    "num_str": "9",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "You shall "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "So with MT, Tg.; LXX, Syr., Vg. rule (cf. Rev. 2:27)"
                        },
                        {
                            "style": "NONE",
                            "text": "break them with a rod of iron;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "You shall dash them to pieces like a potter’s vessel.’ ”"
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 10,
                    "num_str": "10",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Now therefore, be wise, O kings;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Be instructed, you judges of the earth."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 11,
                    "num_str": "11",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Serve the "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": " with fear,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And rejoice with trembling."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 12,
                    "num_str": "12",
                    "verse_parts": [
                        {
                            "style": "FOOTNOTE",
                            "text": "LXX, Vg. Embrace discipline; Tg. Receive instruction"
                        },
                        {
                            "style": "NONE",
                            "text": "Kiss the Son, lest "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "LXX the Lord"
                        },
                        {
                            "style": "NONE",
                            "text": "He be angry,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And you perish "
                        },
                        {
                            "style": "ITALIC",
                            "text": "in"
                        },
                        {
                            "style": "NONE",
                            "text": " the way,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "When His wrath is kindled but a little."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Blessed "
                        },
                        {
                            "style": "ITALIC",
                            "text": "are"
                        },
                        {
                            "style": "NONE",
                            "text": " all those who put their trust in Him."
                        }
                    ]
                }
            ]
        }
    ]
}