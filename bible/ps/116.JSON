{
    "chapter_num": 116,
    "verses_count": 19,
    "paragraphs_list": [
        {
            "type": "section_header",
            "text": "Thanksgiving for Deliverance from Death"
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 1,
                    "num_str": "1",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "I love the "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": ", because He has heard"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "My voice "
                        },
                        {
                            "style": "ITALIC",
                            "text": "and"
                        },
                        {
                            "style": "NONE",
                            "text": " my supplications."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 2,
                    "num_str": "2",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Because He has inclined His ear to me,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Therefore I will call "
                        },
                        {
                            "style": "ITALIC",
                            "text": "upon Him"
                        },
                        {
                            "style": "NONE",
                            "text": " as long as I live."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 3,
                    "num_str": "3",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "The "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "Lit. cords"
                        },
                        {
                            "style": "NONE",
                            "text": "pains of death surrounded me,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And the "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "distresses"
                        },
                        {
                            "style": "NONE",
                            "text": "pangs of Sheol "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "Lit. found me"
                        },
                        {
                            "style": "NONE",
                            "text": "laid hold of me;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "I found trouble and sorrow."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 4,
                    "num_str": "4",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Then I called upon the name of the "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": ":"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "“O "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": ", I implore You, deliver my soul!”"
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 5,
                    "num_str": "5",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Gracious "
                        },
                        {
                            "style": "ITALIC",
                            "text": "is"
                        },
                        {
                            "style": "NONE",
                            "text": " the "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": ", and righteous;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Yes, our God "
                        },
                        {
                            "style": "ITALIC",
                            "text": "is"
                        },
                        {
                            "style": "NONE",
                            "text": " merciful."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 6,
                    "num_str": "6",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "The "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": " preserves the simple;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "I was brought low, and He saved me."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 7,
                    "num_str": "7",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Return to your rest, O my soul,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "For the "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": " has dealt bountifully with you."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 8,
                    "num_str": "8",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "For You have delivered my soul from death,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "My eyes from tears,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "ITALIC",
                            "text": "And"
                        },
                        {
                            "style": "NONE",
                            "text": " my feet from falling."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 9,
                    "num_str": "9",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "I will walk before the "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "In the land of the living."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 10,
                    "num_str": "10",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "I believed, therefore I spoke,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "“I am greatly afflicted.”"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 11,
                    "num_str": "11",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "I said in my haste,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "“All men "
                        },
                        {
                            "style": "ITALIC",
                            "text": "are"
                        },
                        {
                            "style": "NONE",
                            "text": " liars.”"
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 12,
                    "num_str": "12",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "What shall I render to the "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "ITALIC",
                            "text": "For"
                        },
                        {
                            "style": "NONE",
                            "text": " all His benefits toward me?"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 13,
                    "num_str": "13",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "I will take up the cup of salvation,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And call upon the name of the "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": "."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 14,
                    "num_str": "14",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "I will pay my vows to the "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Now in the presence of all His people."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 15,
                    "num_str": "15",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Precious in the sight of the "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "ITALIC",
                            "text": "Is"
                        },
                        {
                            "style": "NONE",
                            "text": " the death of His saints."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 16,
                    "num_str": "16",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "O "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": ", truly I "
                        },
                        {
                            "style": "ITALIC",
                            "text": "am"
                        },
                        {
                            "style": "NONE",
                            "text": " Your servant;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "I "
                        },
                        {
                            "style": "ITALIC",
                            "text": "am"
                        },
                        {
                            "style": "NONE",
                            "text": " Your servant, the son of Your maidservant;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "You have loosed my bonds."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 17,
                    "num_str": "17",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "I will offer to You the sacrifice of thanksgiving,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And will call upon the name of the "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": "."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 18,
                    "num_str": "18",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "I will pay my vows to the "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Now in the presence of all His people,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 19,
                    "num_str": "19",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "In the courts of the "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": "’s house,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "In the midst of you, O Jerusalem."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "Heb. Hallelujah"
                        },
                        {
                            "style": "NONE",
                            "text": "Praise the "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": "!"
                        }
                    ]
                }
            ]
        }
    ]
}