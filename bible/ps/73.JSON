{
    "chapter_num": 73,
    "verses_count": 28,
    "paragraphs_list": [
        {
            "type": "section_header",
            "text": "The Tragedy of the Wicked, and the Blessedness of Trust in God"
        },
        {
            "type": "section_header",
            "text": "A Psalm of Asaph."
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 1,
                    "num_str": "1",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Truly God "
                        },
                        {
                            "style": "ITALIC",
                            "text": "is"
                        },
                        {
                            "style": "NONE",
                            "text": " good to Israel,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "To such as are pure in heart."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 2,
                    "num_str": "2",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "But as for me, my feet had almost stumbled;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "My steps had nearly slipped."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 3,
                    "num_str": "3",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "For I "
                        },
                        {
                            "style": "ITALIC",
                            "text": "was"
                        },
                        {
                            "style": "NONE",
                            "text": " envious of the boastful,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "When I saw the prosperity of the wicked."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 4,
                    "num_str": "4",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "For "
                        },
                        {
                            "style": "ITALIC",
                            "text": "there are"
                        },
                        {
                            "style": "NONE",
                            "text": " no "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "pains"
                        },
                        {
                            "style": "NONE",
                            "text": "pangs in their death,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "But their strength "
                        },
                        {
                            "style": "ITALIC",
                            "text": "is"
                        },
                        {
                            "style": "NONE",
                            "text": " firm."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 5,
                    "num_str": "5",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "They "
                        },
                        {
                            "style": "ITALIC",
                            "text": "are"
                        },
                        {
                            "style": "NONE",
                            "text": " not in trouble "
                        },
                        {
                            "style": "ITALIC",
                            "text": "as other"
                        },
                        {
                            "style": "NONE",
                            "text": " men,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Nor are they plagued like "
                        },
                        {
                            "style": "ITALIC",
                            "text": "other"
                        },
                        {
                            "style": "NONE",
                            "text": " men."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 6,
                    "num_str": "6",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Therefore pride serves as their necklace;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Violence covers them "
                        },
                        {
                            "style": "ITALIC",
                            "text": "like"
                        },
                        {
                            "style": "NONE",
                            "text": " a garment."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 7,
                    "num_str": "7",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Their "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "Tg. face bulges; LXX, Syr., Vg. iniquity bulges"
                        },
                        {
                            "style": "NONE",
                            "text": "eyes bulge with abundance;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "They have more than heart could wish."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 8,
                    "num_str": "8",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "They scoff and speak wickedly "
                        },
                        {
                            "style": "ITALIC",
                            "text": "concerning"
                        },
                        {
                            "style": "NONE",
                            "text": " oppression;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "They speak "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "Proudly"
                        },
                        {
                            "style": "NONE",
                            "text": "loftily."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 9,
                    "num_str": "9",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "They set their mouth against the heavens,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And their tongue walks through the earth."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 10,
                    "num_str": "10",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Therefore his people return here,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And waters of a full "
                        },
                        {
                            "style": "ITALIC",
                            "text": "cup"
                        },
                        {
                            "style": "NONE",
                            "text": " are drained by them."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 11,
                    "num_str": "11",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "And they say, “How does God know?"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And is there knowledge in the Most High?”"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 12,
                    "num_str": "12",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Behold, these "
                        },
                        {
                            "style": "ITALIC",
                            "text": "are"
                        },
                        {
                            "style": "NONE",
                            "text": " the ungodly,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Who are always at ease;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "They increase "
                        },
                        {
                            "style": "ITALIC",
                            "text": "in"
                        },
                        {
                            "style": "NONE",
                            "text": " riches."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 13,
                    "num_str": "13",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Surely I have "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "kept my heart pure in vain"
                        },
                        {
                            "style": "NONE",
                            "text": "cleansed my heart "
                        },
                        {
                            "style": "ITALIC",
                            "text": "in"
                        },
                        {
                            "style": "NONE",
                            "text": " vain,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And washed my hands in innocence."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 14,
                    "num_str": "14",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "For all day long I have been plagued,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And chastened every morning."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 15,
                    "num_str": "15",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "If I had said, “I will speak thus,”"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Behold, I would have been untrue to the generation of Your children."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 16,
                    "num_str": "16",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "When I thought "
                        },
                        {
                            "style": "ITALIC",
                            "text": "how"
                        },
                        {
                            "style": "NONE",
                            "text": " to understand this,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "It "
                        },
                        {
                            "style": "ITALIC",
                            "text": "was"
                        },
                        {
                            "style": "NONE",
                            "text": " "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "troublesome in my eyes"
                        },
                        {
                            "style": "NONE",
                            "text": "too painful for me—"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 17,
                    "num_str": "17",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Until I went into the sanctuary of God;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "ITALIC",
                            "text": "Then"
                        },
                        {
                            "style": "NONE",
                            "text": " I understood their end."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 18,
                    "num_str": "18",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Surely You set them in slippery places;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "You cast them down to destruction."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 19,
                    "num_str": "19",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Oh, how they are "
                        },
                        {
                            "style": "ITALIC",
                            "text": "brought"
                        },
                        {
                            "style": "NONE",
                            "text": " to desolation, as in a moment!"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "They are utterly consumed with terrors."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 20,
                    "num_str": "20",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "As a dream when "
                        },
                        {
                            "style": "ITALIC",
                            "text": "one"
                        },
                        {
                            "style": "NONE",
                            "text": " awakes,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "ITALIC",
                            "text": "So,"
                        },
                        {
                            "style": "NONE",
                            "text": " Lord, when You awake,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "You shall despise their image."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 21,
                    "num_str": "21",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Thus my heart was grieved,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And I was "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "Lit. pierced in my kidneys"
                        },
                        {
                            "style": "NONE",
                            "text": "vexed in my mind."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 22,
                    "num_str": "22",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "I "
                        },
                        {
                            "style": "ITALIC",
                            "text": "was"
                        },
                        {
                            "style": "NONE",
                            "text": " so foolish and ignorant;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "I was "
                        },
                        {
                            "style": "ITALIC",
                            "text": "like"
                        },
                        {
                            "style": "NONE",
                            "text": " a beast before You."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 23,
                    "num_str": "23",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Nevertheless I "
                        },
                        {
                            "style": "ITALIC",
                            "text": "am"
                        },
                        {
                            "style": "NONE",
                            "text": " continually with You;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "You hold "
                        },
                        {
                            "style": "ITALIC",
                            "text": "me"
                        },
                        {
                            "style": "NONE",
                            "text": " by my right hand."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 24,
                    "num_str": "24",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "You will guide me with Your counsel,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And afterward receive me "
                        },
                        {
                            "style": "ITALIC",
                            "text": "to"
                        },
                        {
                            "style": "NONE",
                            "text": " glory."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 25,
                    "num_str": "25",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Whom have I in heaven "
                        },
                        {
                            "style": "ITALIC",
                            "text": "but You?"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And "
                        },
                        {
                            "style": "ITALIC",
                            "text": "there is"
                        },
                        {
                            "style": "NONE",
                            "text": " none upon earth "
                        },
                        {
                            "style": "ITALIC",
                            "text": "that"
                        },
                        {
                            "style": "NONE",
                            "text": " I desire besides You."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 26,
                    "num_str": "26",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "My flesh and my heart fail;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "ITALIC",
                            "text": "But"
                        },
                        {
                            "style": "NONE",
                            "text": " God "
                        },
                        {
                            "style": "ITALIC",
                            "text": "is"
                        },
                        {
                            "style": "NONE",
                            "text": " the "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "Lit. rock"
                        },
                        {
                            "style": "NONE",
                            "text": "strength of my heart and my portion forever."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 27,
                    "num_str": "27",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "For indeed, those who are far from You shall perish;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "You have destroyed all those who "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "Are unfaithful to You"
                        },
                        {
                            "style": "NONE",
                            "text": "desert You for harlotry."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 28,
                    "num_str": "28",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "But "
                        },
                        {
                            "style": "ITALIC",
                            "text": "it is"
                        },
                        {
                            "style": "NONE",
                            "text": " good for me to draw near to God;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "I have put my trust in the Lord "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "God"
                        },
                        {
                            "style": "NONE",
                            "text": ","
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "That I may declare all Your works."
                        }
                    ]
                }
            ]
        }
    ]
}