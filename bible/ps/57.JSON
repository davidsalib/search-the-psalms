{
    "chapter_num": 57,
    "verses_count": 11,
    "paragraphs_list": [
        {
            "type": "section_header",
            "text": "Prayer for Safety from Enemies"
        },
        {
            "type": "section_header",
            "text": "To the Chief Musician. Set to “Do Not Destroy.” A Michtam of David when he fled from Saul into the cave."
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 1,
                    "num_str": "1",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Be merciful to me, O God, be merciful to me!"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "For my soul trusts in You;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And in the shadow of Your wings I will make my refuge,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Until "
                        },
                        {
                            "style": "ITALIC",
                            "text": "these"
                        },
                        {
                            "style": "NONE",
                            "text": " calamities have passed by."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 2,
                    "num_str": "2",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "I will cry out to God Most High,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "To God who performs "
                        },
                        {
                            "style": "ITALIC",
                            "text": "all things"
                        },
                        {
                            "style": "NONE",
                            "text": " for me."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 3,
                    "num_str": "3",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "He shall send from heaven and save me;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "He reproaches the one who "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "snaps at or hounds me, or crushes me"
                        },
                        {
                            "style": "NONE",
                            "text": "would swallow me up. "
                        },
                        {
                            "style": "ITALIC",
                            "text": "Selah"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "God shall send forth His mercy and His truth."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 4,
                    "num_str": "4",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "My soul "
                        },
                        {
                            "style": "ITALIC",
                            "text": "is"
                        },
                        {
                            "style": "NONE",
                            "text": " among lions;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "I lie "
                        },
                        {
                            "style": "ITALIC",
                            "text": "among"
                        },
                        {
                            "style": "NONE",
                            "text": " the sons of men"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Who are set on fire,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Whose teeth "
                        },
                        {
                            "style": "ITALIC",
                            "text": "are"
                        },
                        {
                            "style": "NONE",
                            "text": " spears and arrows,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And their tongue a sharp sword."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 5,
                    "num_str": "5",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Be exalted, O God, above the heavens;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "ITALIC",
                            "text": "Let"
                        },
                        {
                            "style": "NONE",
                            "text": " Your glory "
                        },
                        {
                            "style": "ITALIC",
                            "text": "be"
                        },
                        {
                            "style": "NONE",
                            "text": " above all the earth."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 6,
                    "num_str": "6",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "They have prepared a net for my steps;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "My soul is bowed down;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "They have dug a pit before me;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Into the midst of it they "
                        },
                        {
                            "style": "ITALIC",
                            "text": "themselves"
                        },
                        {
                            "style": "NONE",
                            "text": " have fallen. "
                        },
                        {
                            "style": "ITALIC",
                            "text": "Selah"
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 7,
                    "num_str": "7",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "My heart is steadfast, O God, my heart is steadfast;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "I will sing and give praise."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 8,
                    "num_str": "8",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Awake, my glory!"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Awake, lute and harp!"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "I will awaken the dawn."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 9,
                    "num_str": "9",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "I will praise You, O Lord, among the peoples;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "I will sing to You among the "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "Gentiles"
                        },
                        {
                            "style": "NONE",
                            "text": "nations."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 10,
                    "num_str": "10",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "For Your mercy reaches unto the heavens,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And Your truth unto the clouds."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 11,
                    "num_str": "11",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Be exalted, O God, above the heavens;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "ITALIC",
                            "text": "Let"
                        },
                        {
                            "style": "NONE",
                            "text": " Your glory "
                        },
                        {
                            "style": "ITALIC",
                            "text": "be"
                        },
                        {
                            "style": "NONE",
                            "text": " above all the earth."
                        }
                    ]
                }
            ]
        }
    ]
}