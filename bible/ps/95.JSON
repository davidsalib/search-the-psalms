{
    "chapter_num": 95,
    "verses_count": 11,
    "paragraphs_list": [
        {
            "type": "section_header",
            "text": "A Call to Worship and Obedience"
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 1,
                    "num_str": "1",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Oh come, let us sing to the "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": "!"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Let us shout joyfully to the Rock of our salvation."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 2,
                    "num_str": "2",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Let us come before His presence with thanksgiving;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Let us shout joyfully to Him with psalms."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 3,
                    "num_str": "3",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "For the "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": " "
                        },
                        {
                            "style": "ITALIC",
                            "text": "is"
                        },
                        {
                            "style": "NONE",
                            "text": " the great God,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And the great King above all gods."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 4,
                    "num_str": "4",
                    "verse_parts": [
                        {
                            "style": "FOOTNOTE",
                            "text": "In His possession"
                        },
                        {
                            "style": "NONE",
                            "text": "In His hand "
                        },
                        {
                            "style": "ITALIC",
                            "text": "are"
                        },
                        {
                            "style": "NONE",
                            "text": " the deep places of the earth;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "The heights of the hills "
                        },
                        {
                            "style": "ITALIC",
                            "text": "are"
                        },
                        {
                            "style": "NONE",
                            "text": " His also."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 5,
                    "num_str": "5",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "The sea "
                        },
                        {
                            "style": "ITALIC",
                            "text": "is"
                        },
                        {
                            "style": "NONE",
                            "text": " His, for He made it;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And His hands formed the dry "
                        },
                        {
                            "style": "ITALIC",
                            "text": "land."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 6,
                    "num_str": "6",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Oh come, let us worship and bow down;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Let us kneel before the "
                        },
                        {
                            "style": "DIVINE_NAME",
                            "text": "Lord"
                        },
                        {
                            "style": "NONE",
                            "text": " our Maker."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 7,
                    "num_str": "7",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "For He "
                        },
                        {
                            "style": "ITALIC",
                            "text": "is"
                        },
                        {
                            "style": "NONE",
                            "text": " our God,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And we "
                        },
                        {
                            "style": "ITALIC",
                            "text": "are"
                        },
                        {
                            "style": "NONE",
                            "text": " the people of His pasture,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And the sheep "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "Under His care"
                        },
                        {
                            "style": "NONE",
                            "text": "of His hand."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Today, if you will hear His voice:"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 8,
                    "num_str": "8",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "“Do not harden your hearts, as in the "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "Or Meribah, lit. Strife, Contention"
                        },
                        {
                            "style": "NONE",
                            "text": "rebellion,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "As "
                        },
                        {
                            "style": "ITALIC",
                            "text": "in"
                        },
                        {
                            "style": "NONE",
                            "text": " the day of "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "Or Massah, lit. Trial, Testing"
                        },
                        {
                            "style": "NONE",
                            "text": "trial in the wilderness,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 9,
                    "num_str": "9",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "When your fathers tested Me;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "They tried Me, though they saw My work."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 10,
                    "num_str": "10",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "For forty years I was "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "disgusted"
                        },
                        {
                            "style": "NONE",
                            "text": "grieved with "
                        },
                        {
                            "style": "ITALIC",
                            "text": "that"
                        },
                        {
                            "style": "NONE",
                            "text": " generation,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And said, ‘It "
                        },
                        {
                            "style": "ITALIC",
                            "text": "is"
                        },
                        {
                            "style": "NONE",
                            "text": " a people who go astray in their hearts,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And they do not know My ways.’"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 11,
                    "num_str": "11",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "So I swore in My wrath,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "‘They shall not enter My rest.’ ”"
                        }
                    ]
                }
            ]
        }
    ]
}