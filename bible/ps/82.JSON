{
    "chapter_num": 82,
    "verses_count": 8,
    "paragraphs_list": [
        {
            "type": "section_header",
            "text": "A Plea for Justice"
        },
        {
            "type": "section_header",
            "text": "A Psalm of Asaph."
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 1,
                    "num_str": "1",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "God stands in the congregation of "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "Heb. El, lit. God"
                        },
                        {
                            "style": "NONE",
                            "text": "the mighty;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "He judges among the "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "Judges; Heb. elohim, lit. mighty ones or gods"
                        },
                        {
                            "style": "NONE",
                            "text": "gods."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 2,
                    "num_str": "2",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "How long will you judge unjustly,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And show partiality to the wicked? "
                        },
                        {
                            "style": "ITALIC",
                            "text": "Selah"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 3,
                    "num_str": "3",
                    "verse_parts": [
                        {
                            "style": "FOOTNOTE",
                            "text": "Vindicate"
                        },
                        {
                            "style": "NONE",
                            "text": "Defend the poor and fatherless;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Do justice to the afflicted and needy."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 4,
                    "num_str": "4",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Deliver the poor and needy;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "Free "
                        },
                        {
                            "style": "ITALIC",
                            "text": "them"
                        },
                        {
                            "style": "NONE",
                            "text": " from the hand of the wicked."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 5,
                    "num_str": "5",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "They do not know, nor do they understand;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "They walk about in darkness;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "All the foundations of the earth are "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "moved"
                        },
                        {
                            "style": "NONE",
                            "text": "unstable."
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 6,
                    "num_str": "6",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "I said, “You "
                        },
                        {
                            "style": "ITALIC",
                            "text": "are"
                        },
                        {
                            "style": "NONE",
                            "text": " "
                        },
                        {
                            "style": "FOOTNOTE",
                            "text": "Judges; Heb. elohim, lit. mighty ones or gods"
                        },
                        {
                            "style": "NONE",
                            "text": "gods,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And all of you "
                        },
                        {
                            "style": "ITALIC",
                            "text": "are"
                        },
                        {
                            "style": "NONE",
                            "text": " children of the Most High."
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        }
                    ]
                },
                {
                    "num_int": 7,
                    "num_str": "7",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "But you shall die like men,"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "And fall like one of the princes.”"
                        }
                    ]
                }
            ]
        },
        {
            "type": "section_paragraph",
            "verses_list": [
                {
                    "num_int": 8,
                    "num_str": "8",
                    "verse_parts": [
                        {
                            "style": "NONE",
                            "text": "Arise, O God, judge the earth;"
                        },
                        {
                            "style": "LINE_BREAK",
                            "text": "\n"
                        },
                        {
                            "style": "NONE",
                            "text": "For You shall inherit all nations."
                        }
                    ]
                }
            ]
        }
    ]
}